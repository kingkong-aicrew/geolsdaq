# 두 번째 월급 — 백엔드 환경변수 예시
# ⚠️ 이 파일은 키 이름만. 실제 값은 .env 파일에 (.gitignore 됨)

# Supabase  (신규 키 체계 2025~: Settings → API Keys 에서 발급. legacy eyJ... 는 2026말 폐기)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...      # publishable (프론트/읽기, RLS 적용). legacy anon(eyJ...)도 당분간 호환
SUPABASE_SERVICE_KEY=sb_secret_...        # secret (백엔드/배치 전용·전체권한 — 절대 노출 ✕)

# CORS — 콤마 구분 화이트리스트
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limit (IP/분)
RATE_CALC_PER_MINUTE=30
RATE_STASH_PER_MINUTE=10
RATE_PARALLEL_PER_MINUTE=20
RATE_POSTS_PER_MINUTE=10
RATE_REACT_PER_MINUTE=30
RATE_DEFAULT_PER_MINUTE=60

# 사이트 (OG image 절대경로 생성용)
SITE_ORIGIN=http://localhost:3000

# Twelve Data — US 주식·환율 EOD 배치용 (무료 800콜/일). yfinance 대체.
# https://twelvedata.com/pricing 에서 무료 키 발급(10초)
TWELVEDATA_API_KEY=
